<ui:FluentWindow x:Class="Gentastic.App.Views.AgeConfirmationDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
                 Title="Gentastic - Age confirmation"
                 Width="520" Height="330"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="" />

        <StackPanel Grid.Row="1" Margin="28,8,28,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <fa:IconBlock Icon="ShieldHalved" FontSize="20" VerticalAlignment="Center"
                              Foreground="{StaticResource AccentBrush}" />
                <TextBlock Text="Adult content - age confirmation" FontSize="20" FontWeight="SemiBold"
                           Margin="12,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,16"
                       Text="You are about to enable the adult (18+) models, which can produce explicit content. Please confirm the following before continuing." />

            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="14,12">
                <CheckBox x:Name="AgeCheck" HorizontalContentAlignment="Left"
                          Checked="OnCheckChanged" Unchecked="OnCheckChanged">
                    <TextBlock TextWrapping="Wrap" MaxWidth="410"
                               Text="I confirm that I am of legal age to view adult content in my country or jurisdiction - at least 18 years old, or 21 where required by law." />
                </CheckBox>
            </Border>
        </StackPanel>

        <Border Grid.Row="2" Padding="28,14" Background="{DynamicResource ControlFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Cancel" Click="OnCancel" />
                <Button x:Name="ConfirmButton" Style="{StaticResource PrimaryButtonStyle}" Margin="10,0,0,0"
                        IsEnabled="False" Click="OnConfirm" Content="Confirm" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
