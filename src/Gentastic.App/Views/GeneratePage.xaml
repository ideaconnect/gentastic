<Page x:Class="Gentastic.App.Views.GeneratePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      Title="Generate">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Margin="28,20,28,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="466" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Controls -->
        <Grid Grid.Column="0" Margin="0,0,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,12">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                    <fa:IconBlock Icon="WandMagicSparkles" FontSize="18" VerticalAlignment="Center"
                                  Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="Text to image" FontSize="21" FontWeight="SemiBold"
                               Margin="10,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="Preset" Style="{StaticResource FieldLabelStyle}" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}"
                              DisplayMemberPath="Name" />
                    <ui:Button Grid.Column="1" Content="Delete" Icon="{ui:SymbolIcon Delete24}" Margin="8,0,0,0"
                               Command="{Binding DeletePresetCommand}" />
                </Grid>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" PlaceholderText="Name to save current settings…"
                                Text="{Binding PresetName, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:Button Grid.Column="1" Content="Save preset" Icon="{ui:SymbolIcon Save24}" Margin="8,0,0,0"
                               Command="{Binding SavePresetCommand}" />
                </Grid>

                <TextBlock Text="Prompt" Style="{StaticResource FieldLabelStyle}" />
                <ui:TextBox PlaceholderText="Describe the image you want…"
                            Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                            AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80" Margin="0,0,0,12" />

                <TextBlock Text="Negative prompt" Style="{StaticResource FieldLabelStyle}" />
                <ui:TextBox PlaceholderText="What to avoid…"
                            Text="{Binding NegativePrompt, UpdateSourceTrigger=PropertyChanged}"
                            IsEnabled="{Binding IsNegativePromptEnabled}"
                            AcceptsReturn="True" TextWrapping="Wrap" MinHeight="52" Margin="0,0,0,2" />
                <TextBlock Text="{Binding NegativePromptHint}" TextWrapping="Wrap"
                           FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Margin="0,0,0,12" />

                <ui:ToggleSwitch Content="Use an input image (image-to-image)"
                                 IsChecked="{Binding UseInputImage}" Margin="0,0,0,8" />
                <Border Visibility="{Binding UseInputImage, Converter={StaticResource BoolToVis}}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="10" Margin="0,0,0,12">
                    <StackPanel>
                        <Border AllowDrop="True" Drop="OnInitImageDrop" DragOver="OnInitImageDragOver"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                CornerRadius="4" MinHeight="120">
                            <Grid>
                                <TextBlock Text="Drop an image here, or Browse"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                <Image Source="{Binding InitImagePreview}" Stretch="Uniform"
                                       MaxHeight="180" Margin="4" />
                            </Grid>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <ui:Button Content="Browse…" Icon="{ui:SymbolIcon FolderOpen24}"
                                       Command="{Binding BrowseInitImageCommand}" />
                            <ui:Button Content="Clear" Command="{Binding ClearInitImageCommand}" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="Denoise strength (higher = more change)" Margin="0,10,0,4" />
                        <Slider Minimum="0.1" Maximum="1.0" Value="{Binding DenoiseStrength}"
                                TickFrequency="0.05" IsSnapToTickEnabled="True" />
                    </StackPanel>
                </Border>

                <TextBlock Text="Model" Style="{StaticResource FieldLabelStyle}" />
                <ComboBox ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}"
                          DisplayMemberPath="DisplayName" HorizontalAlignment="Stretch" Margin="0,0,0,12" />

                <TextBlock Text="Size" Style="{StaticResource FieldLabelStyle}" />
                <ComboBox ItemsSource="{Binding SizePresets}" SelectedItem="{Binding SelectedSize}"
                          DisplayMemberPath="Label" HorizontalAlignment="Stretch" Margin="0,0,0,12" />

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Steps" Style="{StaticResource FieldLabelStyle}" />
                        <ui:NumberBox Value="{Binding Steps, Mode=TwoWay}" Minimum="1" Maximum="100" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="CFG" Style="{StaticResource FieldLabelStyle}" />
                        <ui:NumberBox Value="{Binding Cfg, Mode=TwoWay}" Minimum="1" Maximum="20" SmallChange="0.5" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Seed (-1 = random)" Style="{StaticResource FieldLabelStyle}" />
                <ui:NumberBox Value="{Binding Seed, Mode=TwoWay}" Minimum="-1" Margin="0,0,0,12" />

                <TextBlock Text="Sampler" Style="{StaticResource FieldLabelStyle}" />
                <ComboBox ItemsSource="{Binding Samplers}" SelectedItem="{Binding SelectedSampler}"
                          HorizontalAlignment="Stretch" Margin="0,0,0,4" />
            </StackPanel>
            </ScrollViewer>

            <!-- Pinned action bar -->
            <StackPanel Grid.Row="1" Margin="0,14,10,16">
                <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                        Margin="0,0,0,14" Opacity="0.6" />
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding GenerateCommand}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="WandMagicSparkles" FontSize="14" Foreground="White"
                                          VerticalAlignment="Center" />
                            <TextBlock Text="Generate" Margin="9,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <ui:Button Content="Cancel" Margin="10,0,0,0" Icon="{ui:SymbolIcon Dismiss24}"
                               Command="{Binding CancelCommand}"
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                    <ui:Button Icon="{ui:SymbolIcon FolderOpen24}" Command="{Binding OpenOutputFolderCommand}"
                               Margin="10,0,0,0" ToolTip="Open output folder" />
                </StackPanel>
                <ProgressBar Minimum="0" Maximum="1" Value="{Binding Progress}" Height="4" Margin="0,10,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,10,0,0" MaxHeight="40"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- Preview -->
        <ui:Card Grid.Column="1">
            <Grid>
                <TextBlock Text="Your generated image will appear here"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <Image Source="{Binding PreviewImage}" Stretch="Uniform" />
                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </ui:Card>
    </Grid>
</Page>
