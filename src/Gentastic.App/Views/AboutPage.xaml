<Page x:Class="Gentastic.App.Views.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      Title="About">
    <!-- Branded dark splash so the white text and white company-logo card read in any theme. -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#1C1E26" Offset="0" />
                <GradientStop Color="#131318" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        MaxWidth="440" Margin="24,44,24,44">

                <!-- Gentastic logo (already carries the "Gentastic" wordmark, so no separate title) -->
                <Image Source="/Assets/icon-app.png" Width="176" Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" />

                <TextBlock Text="{Binding VersionText}" HorizontalAlignment="Center" Margin="0,18,0,0"
                           Foreground="White" Opacity="0.72" />

                <TextBlock Text="{Binding Tagline}" TextWrapping="Wrap" TextAlignment="Center"
                           HorizontalAlignment="Center" Margin="0,16,0,0" MaxWidth="360"
                           Foreground="White" Opacity="0.8" />

                <!-- Author -->
                <TextBlock HorizontalAlignment="Center" Margin="0,22,0,0" Foreground="White">
                    <Run Text="Created by " Foreground="#B3FFFFFF" /><Run
                        Text="{Binding AuthorName, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>

                <!-- Links: project website + GitHub -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Style="{StaticResource SecondaryButtonStyle}" Foreground="White"
                            Command="{Binding OpenWebsiteCommand}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Globe" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Text="Website" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Foreground="White"
                            Command="{Binding OpenGitHubCommand}" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Github" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="GitHub" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Open-source acknowledgements + link to the full third-party notices -->
                <Border Background="#14FFFFFF" CornerRadius="12" Padding="18,14" Margin="0,28,0,0">
                    <StackPanel>
                        <TextBlock Text="Open source" Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" />
                        <TextBlock Text="{Binding LicenseLine}" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Foreground="White" Opacity="0.82" FontSize="12" />
                        <TextBlock Text="{Binding Acknowledgements}" TextWrapping="Wrap" Margin="0,8,0,0"
                                   Foreground="White" Opacity="0.62" FontSize="11.5" />
                        <Button Style="{StaticResource SecondaryButtonStyle}" Foreground="White"
                                Command="{Binding OpenLicensesCommand}" HorizontalAlignment="Left"
                                Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="ScaleBalanced" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="Third-party licenses" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Company logo (IDCT) on a white rounded card so the black mark stays legible -->
                <Border Background="White" CornerRadius="16" Padding="22,16" Margin="0,26,0,0"
                        HorizontalAlignment="Center">
                    <Image Source="/Assets/idct-logo.png" Width="122" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>

                <TextBlock Text="{Binding Copyright}" HorizontalAlignment="Center" Margin="0,20,0,0"
                           FontSize="12" Foreground="White" Opacity="0.5" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
