<ui:FluentWindow x:Class="Gentastic.App.Views.RuntimeDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
                 Title="Gentastic — Runtime"
                 Width="580" Height="620"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="" />

        <StackPanel Grid.Row="1" Margin="28,8,28,0">
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <fa:IconBlock Icon="Microchip" FontSize="20" VerticalAlignment="Center"
                              Foreground="{StaticResource AccentBrush}" />
                <TextBlock Text="Choose your compute runtime" FontSize="20" FontWeight="SemiBold"
                           Margin="12,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="Gentastic detected the following. Pick a runtime, or let it decide automatically."
                       TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,14" />

            <!-- Detected hardware -->
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="12,10" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <fa:IconBlock Icon="Display" FontSize="13" VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{Binding HardwareSummary}" TextWrapping="Wrap" Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Runtime options -->
            <ListBox ItemsSource="{Binding Options}" SelectedItem="{Binding SelectedOption}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,0,8" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="IsEnabled" Value="{Binding IsSelectable}" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Ring" CornerRadius="10" BorderThickness="2"
                                            BorderBrush="Transparent"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                                        <Border CornerRadius="8" Padding="14,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <fa:IconBlock Grid.Column="0" Icon="{Binding Icon}" FontSize="18"
                                                              VerticalAlignment="Center" Width="26"
                                                              Foreground="{Binding IconBrush}" />
                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14.5" />
                                                    <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" FontSize="12.5"
                                                               Margin="0,3,0,0"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Ring" Property="BorderBrush" Value="{StaticResource SidebarMutedBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Ring" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Ring" Property="Opacity" Value="0.5" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="28,14" Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Grid>
                <TextBlock VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Text="You can change this any time in Settings." />
                <Button Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Right"
                        Click="OnContinue">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Continue" VerticalAlignment="Center" />
                        <fa:IconBlock Icon="ArrowRight" FontSize="13" Foreground="White" Margin="9,0,0,0"
                                      VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
