<Page x:Class="Gentastic.App.Views.GalleryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      Title="Gallery">
    <Grid Margin="28,20,28,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <fa:IconBlock Icon="Images" FontSize="19" VerticalAlignment="Center"
                              Foreground="{StaticResource AccentBrush}" />
                <TextBlock Text="Gallery" FontSize="21" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="ArrowsRotate" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Refresh" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding OpenFolderCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="FolderOpen" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Open folder" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="0,0,18,0"
                     Background="Transparent" BorderThickness="0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,10,10" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Ring" CornerRadius="12" BorderThickness="2"
                                            BorderBrush="Transparent" Padding="3">
                                        <Border CornerRadius="9" ClipToBounds="True">
                                            <Image Source="{Binding Thumbnail}" Width="120" Height="120"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Ring" Property="BorderBrush" Value="{StaticResource SidebarMutedBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Ring" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <ui:Card Grid.Column="1" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="8" ClipToBounds="True">
                        <Image Source="{Binding SelectedImage}" Stretch="Uniform" />
                    </Border>
                    <ScrollViewer Grid.Row="1" MaxHeight="150" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                        <TextBox Text="{Binding Metadata}" IsReadOnly="True" TextWrapping="Wrap"
                                 BorderThickness="0" Background="Transparent" FontSize="12"
                                 Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </ScrollViewer>
                    <Button Grid.Row="2" Style="{StaticResource SecondaryButtonStyle}" Margin="0,12,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedItem}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="TrashCan" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Text="Delete" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </ui:Card>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,14">
            <fa:IconBlock Icon="Images" FontSize="12" VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="{Binding Status}" Margin="7,0,0,0" TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        </StackPanel>
    </Grid>
</Page>
