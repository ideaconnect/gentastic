<Page x:Class="Gentastic.App.Views.GalleryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Gallery">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Gallery" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" />
            <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowClockwise24}"
                       Command="{Binding RefreshCommand}" Margin="16,0,0,0" VerticalAlignment="Center" />
            <ui:Button Content="Open folder" Icon="{ui:SymbolIcon FolderOpen24}"
                       Command="{Binding OpenFolderCommand}" Margin="8,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="0,0,16,0"
                     Background="Transparent" BorderThickness="0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="130" Height="130" Margin="4" CornerRadius="6"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="4" />
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ui:Card Grid.Column="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Image Grid.Row="0" Source="{Binding SelectedImage}" Stretch="Uniform" />
                    <ScrollViewer Grid.Row="1" MaxHeight="180" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                        <TextBox Text="{Binding Metadata}" IsReadOnly="True" TextWrapping="Wrap"
                                 BorderThickness="0" Background="Transparent" FontSize="12" />
                    </ScrollViewer>
                    <ui:Button Grid.Row="2" Content="Delete" Icon="{ui:SymbolIcon Delete24}" Margin="0,10,0,0"
                               Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedItem}"
                               HorizontalAlignment="Left" />
                </Grid>
            </ui:Card>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding Status}" Margin="0,12,0,0"
                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" />
    </Grid>
</Page>
