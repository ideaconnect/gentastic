<Page x:Class="Gentastic.App.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Settings">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,16" />

            <!-- Runtime -->
            <ui:Card Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Runtime" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding HardwareSummary}" />
                    <TextBlock Text="{Binding BackendStatus}" Margin="0,4,0,10"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="Preferred backend" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding BackendOptions}" SelectedItem="{Binding PreferredBackend}"
                              HorizontalAlignment="Left" MinWidth="180" Margin="0,0,0,10" />
                    <TextBlock Text="Detected adapters" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding Adapters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Margin="0,2,0,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ui:Card>

            <!-- Appearance -->
            <ui:Card Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8" />
                    <TextBlock Text="Theme" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding Theme}"
                              HorizontalAlignment="Left" MinWidth="180" />
                </StackPanel>
            </ui:Card>

            <!-- Model cache -->
            <ui:Card Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Model cache" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding CacheRoot}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,4,0,10" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <Run Text="On disk: " /><Run Text="{Binding CacheSize}" />
                    </TextBlock>
                    <TextBlock Text="Cache folder override (blank = default; applies after restart)"
                               FontWeight="SemiBold" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" PlaceholderText="Default location"
                                    Text="{Binding CacheDirectoryOverride, UpdateSourceTrigger=PropertyChanged}" />
                        <ui:Button Grid.Column="1" Content="Browse…" Margin="8,0,0,0"
                                   Command="{Binding BrowseCacheDirectoryCommand}" />
                    </Grid>
                    <ui:Button Content="Open cache folder" Icon="{ui:SymbolIcon FolderOpen24}"
                               Command="{Binding OpenCacheFolderCommand}" HorizontalAlignment="Left" />
                </StackPanel>
            </ui:Card>

            <!-- Hugging Face -->
            <ui:Card Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Hugging Face" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding TokenStatus}" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="Access token" FontWeight="SemiBold" Margin="0,10,0,4" />
                    <ui:TextBox PlaceholderText="hf_… (needed for gated models)"
                                Text="{Binding HuggingFaceToken, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </ui:Card>

            <!-- Updates -->
            <ui:Card Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Updates" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8" />
                    <ui:Button Content="Check for updates" Icon="{ui:SymbolIcon ArrowClockwise24}"
                               Command="{Binding CheckForUpdatesCommand}" HorizontalAlignment="Left" />
                    <TextBlock Text="{Binding UpdateStatus}" TextWrapping="Wrap" Margin="0,8,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:HyperlinkButton Content="View releases"
                                        NavigateUri="https://github.com/ideaconnect/gentastic/releases"
                                        Margin="0,4,0,0" HorizontalAlignment="Left" />
                </StackPanel>
            </ui:Card>

            <StackPanel Orientation="Horizontal">
                <ui:Button Content="Save" Appearance="Primary" Icon="{ui:SymbolIcon Save24}"
                           Command="{Binding SaveCommand}" />
                <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Command="{Binding RefreshCommand}" Margin="8,0,0,0" />
            </StackPanel>
            <TextBlock Text="{Binding SaveStatus}" Margin="0,8,0,0" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        </StackPanel>
    </ScrollViewer>
</Page>
