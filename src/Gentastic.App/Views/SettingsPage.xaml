<Page x:Class="Gentastic.App.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
      Title="Settings">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,20,28,20" MaxWidth="720" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                <fa:IconBlock Icon="Gear" FontSize="19" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" />
                <TextBlock Text="Settings" FontSize="21" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Runtime -->
            <ui:Card Padding="18" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <fa:IconBlock Icon="Microchip" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="Runtime" FontWeight="SemiBold" FontSize="15" Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding HardwareSummary}" />
                    <TextBlock Text="{Binding BackendStatus}" Margin="0,4,0,12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <TextBlock Text="RUNTIME BACKENDS" Style="{StaticResource FieldLabelStyle}" />
                    <ItemsControl ItemsSource="{Binding Probes}" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,9">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <fa:IconBlock Grid.Column="0" Icon="{Binding Icon}" FontSize="15" Width="22"
                                                  VerticalAlignment="Center" Foreground="{Binding IconBrush}" />
                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13.5" />
                                        <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" FontSize="12" Margin="0,1,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="PREFERRED BACKEND" Style="{StaticResource FieldLabelStyle}" />
                    <StackPanel Orientation="Horizontal">
                        <ComboBox ItemsSource="{Binding BackendOptions}" SelectedItem="{Binding PreferredBackend}"
                                  MinWidth="190" VerticalAlignment="Center" />
                        <Button Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0"
                                Command="{Binding ReDetectRuntimeCommand}">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="MagnifyingGlass" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="Re-detect…" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Appearance -->
            <ui:Card Padding="18" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <fa:IconBlock Icon="Palette" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="15" Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="THEME" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding Theme}"
                              HorizontalAlignment="Left" MinWidth="190" />
                </StackPanel>
            </ui:Card>

            <!-- Content -->
            <ui:Card Padding="18" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <fa:IconBlock Icon="ShieldHalved" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="Content" FontWeight="SemiBold" FontSize="15" Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <ui:ToggleSwitch Content="Show adult models (18+)" IsChecked="{Binding ShowAdultModels}"
                                     ToolTip="Reveals adult-only models in the picker and manager. Applies after restart." />
                </StackPanel>
            </ui:Card>

            <!-- Model cache -->
            <ui:Card Padding="18" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <fa:IconBlock Icon="HardDrive" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="Model cache" FontWeight="SemiBold" FontSize="15" Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding CacheRoot}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,4,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <Run Text="On disk: " /><Run Text="{Binding CacheSize}" />
                    </TextBlock>
                    <TextBlock Text="CACHE FOLDER" Style="{StaticResource FieldLabelStyle}"
                               ToolTip="Blank = default location. Applies after restart." />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" PlaceholderText="Default location"
                                    Text="{Binding CacheDirectoryOverride, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0"
                                Content="Browse…" Command="{Binding BrowseCacheDirectoryCommand}" />
                    </Grid>
                    <Button Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left"
                            Command="{Binding OpenCacheFolderCommand}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="FolderOpen" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="Open cache folder" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ui:Card>

            <!-- Hugging Face -->
            <ui:Card Padding="18" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <fa:IconBlock Icon="Robot" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="Hugging Face" FontWeight="SemiBold" FontSize="15" Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding TokenStatus}" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="ACCESS TOKEN" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6" />
                    <ui:TextBox PlaceholderText="hf_… (needed for gated models)"
                                Text="{Binding HuggingFaceToken, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </ui:Card>

            <!-- Updates -->
            <ui:Card Padding="18" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <fa:IconBlock Icon="CloudArrowDown" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="Updates" FontWeight="SemiBold" FontSize="15" Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left"
                            Command="{Binding CheckForUpdatesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="ArrowsRotate" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="Check for updates" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{Binding UpdateStatus}" TextWrapping="Wrap" Margin="0,10,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:HyperlinkButton Content="View releases"
                                        NavigateUri="https://github.com/ideaconnect/gentastic/releases"
                                        Margin="0,4,0,0" HorizontalAlignment="Left" />
                </StackPanel>
            </ui:Card>

            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="FloppyDisk" FontSize="13" Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Text="Save" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefreshCommand}" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="ArrowsRotate" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Refresh" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
            <TextBlock Text="{Binding SaveStatus}" Margin="0,10,0,0" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        </StackPanel>
    </ScrollViewer>
</Page>
