<ui:FluentWindow x:Class="Gentastic.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
                 Title="Gentastic"
                 Width="1180" Height="780"
                 MinWidth="940" MinHeight="600"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="232" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Brand -->
                <Border DockPanel.Dock="Top" Height="64" Padding="18,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="30" Height="30" CornerRadius="9" Background="{StaticResource AccentBrush}">
                            <fa:IconBlock Icon="WandMagicSparkles" FontSize="14" Foreground="White"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Gentastic" Foreground="White" FontSize="16" FontWeight="SemiBold"
                                   Margin="12,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Footer nav -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,14">
                    <RadioButton x:Name="NavSettings" Style="{StaticResource NavItemStyle}" GroupName="Nav"
                                 Tag="SettingsPage" Checked="OnNavChecked">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Gear" FontSize="15" Width="24" />
                            <TextBlock Text="Settings" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Main nav -->
                <StackPanel Margin="12,4,12,0">
                    <TextBlock Text="WORKSPACE" Foreground="{StaticResource SidebarMutedBrush}" FontSize="11"
                               FontWeight="SemiBold" Margin="16,6,0,6" />
                    <RadioButton x:Name="NavGenerate" Style="{StaticResource NavItemStyle}" GroupName="Nav"
                                 Tag="GeneratePage" Checked="OnNavChecked">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="WandMagicSparkles" FontSize="15" Width="24" />
                            <TextBlock Text="Generate" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavModels" Style="{StaticResource NavItemStyle}" GroupName="Nav"
                                 Tag="ModelsPage" Checked="OnNavChecked">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="CubesStacked" FontSize="15" Width="24" />
                            <TextBlock Text="Models" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavGallery" Style="{StaticResource NavItemStyle}" GroupName="Nav"
                                 Tag="GalleryPage" Checked="OnNavChecked">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Images" FontSize="15" Width="24" />
                            <TextBlock Text="Gallery" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ui:TitleBar Grid.Row="0" Title="" />
            <Frame Grid.Row="1" x:Name="ContentFrame" NavigationUIVisibility="Hidden" />
        </Grid>
    </Grid>
</ui:FluentWindow>
