<ui:FluentWindow x:Class="Gentastic.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
                 Title="Gentastic"
                 Icon="/Assets/icon.ico"
                 Width="1180" Height="780"
                 MinWidth="940" MinHeight="600"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="232" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Brand: the icon already carries the "Gentastic" wordmark, shown full-width.
                     HighQuality scaling (Fant) smooths the downscale from 717px so it isn't aliased. -->
                <Border DockPanel.Dock="Top" Padding="16,16,16,8">
                    <Image Source="/Assets/icon-app.png" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>

                <!-- Footer nav -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,12">
                    <!-- About -->
                    <RadioButton x:Name="NavAbout" Style="{StaticResource NavItemStyle}" GroupName="Nav"
                                 Tag="AboutPage" Checked="OnNavChecked">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="CircleInfo" FontSize="15" Width="24" />
                            <TextBlock Text="About" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <!-- Report an issue (opens the project's GitHub issues) -->
                    <Button Style="{StaticResource SidebarActionStyle}" Command="{Binding ReportIssueCommand}"
                            ToolTip="Open the project's issue tracker on GitHub">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Bug" FontSize="15" Width="24" VerticalAlignment="Center" />
                            <TextBlock Text="Report an issue" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Settings -->
                    <RadioButton x:Name="NavSettings" Style="{StaticResource NavItemStyle}" GroupName="Nav"
                                 Tag="SettingsPage" Checked="OnNavChecked">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Gear" FontSize="15" Width="24" />
                            <TextBlock Text="Settings" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <!-- Buy me a coffee (support CTA, below the nav rows) -->
                    <Button Style="{StaticResource SidebarCoffeeButtonStyle}" Command="{Binding OpenCoffeeCommand}"
                            ToolTip="Support Gentastic - buymeacoffee.com/idct" Margin="0,8,0,2">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="MugHot" FontSize="14" Width="22" VerticalAlignment="Center" />
                            <TextBlock Text="Buy me a coffee" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Check for updates - bottom corner. Auto-runs once at startup; click to re-check. -->
                    <Border Height="1" Margin="4,8,4,6" Opacity="0.4"
                            Background="{StaticResource SidebarMutedBrush}" />
                    <Button Style="{StaticResource SidebarUpdateStyle}" Command="{Binding CheckForUpdatesCommand}"
                            ToolTip="{Binding UpdateStatus}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="ArrowsRotate" FontSize="11" Width="20" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding UpdateStatus}" VerticalAlignment="Center"
                                       MaxWidth="150" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Button>
                    <!-- Only shown when a newer release actually exists -->
                    <Button Style="{StaticResource SidebarUpdateStyle}" Command="{Binding OpenLatestReleaseCommand}"
                            Foreground="{StaticResource AccentBrush}"
                            Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}"
                            ToolTip="Open the latest release on GitHub">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Download" FontSize="11" Width="20" VerticalAlignment="Center" />
                            <TextBlock Text="Download the update" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Main nav -->
                <StackPanel Margin="12,4,12,0">
                    <TextBlock Text="WORKSPACE" Foreground="{StaticResource SidebarMutedBrush}" FontSize="11"
                               FontWeight="SemiBold" Margin="16,6,0,6" />
                    <RadioButton x:Name="NavGenerate" Style="{StaticResource NavItemStyle}" GroupName="Nav"
                                 Tag="GeneratePage" Checked="OnNavChecked">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="WandMagicSparkles" FontSize="15" Width="24" />
                            <TextBlock Text="Image generation" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavModels" Style="{StaticResource NavItemStyle}" GroupName="Nav"
                                 Tag="ModelsPage" Checked="OnNavChecked">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="CubesStacked" FontSize="15" Width="24" />
                            <TextBlock Text="Models" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavGallery" Style="{StaticResource NavItemStyle}" GroupName="Nav"
                                 Tag="GalleryPage" Checked="OnNavChecked">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Images" FontSize="15" Width="24" />
                            <TextBlock Text="Gallery" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ui:TitleBar Grid.Row="0" Title="" />
            <Frame Grid.Row="1" x:Name="ContentFrame" NavigationUIVisibility="Hidden" />
        </Grid>
    </Grid>
</ui:FluentWindow>
