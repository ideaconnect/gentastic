<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand accent -->
    <Color x:Key="AccentColor">#6366F1</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="#6366F1" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#7C80F5" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#4F52D4" />

    <!-- Sidebar palette - stays dark in both themes (Slack-style branded rail) -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#16171B" />
    <SolidColorBrush x:Key="SidebarItemHoverBrush" Color="#23252C" />
    <SolidColorBrush x:Key="SidebarItemActiveBrush" Color="#2B2E4A" />
    <SolidColorBrush x:Key="SidebarTextBrush" Color="#B6BAC4" />
    <SolidColorBrush x:Key="SidebarTextActiveBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SidebarMutedBrush" Color="#71757F" />

    <!-- Sidebar nav item: a RadioButton styled as a Discord/Slack sidebar row -->
    <Style x:Key="NavItemStyle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="8" />
                        <Rectangle x:Name="Bar" Width="3" Height="18" RadiusX="2" RadiusY="2"
                                   Fill="{StaticResource AccentBrush}" HorizontalAlignment="Left"
                                   Margin="0" Visibility="Collapsed" />
                        <ContentPresenter Margin="16,0,12,0" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource SidebarItemHoverBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource SidebarTextActiveBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource SidebarItemActiveBrush}" />
                            <Setter TargetName="Bar" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground" Value="{StaticResource SidebarTextActiveBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Compact accent primary button (kills the full-width look) -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="B" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="B" Property="Background" Value="{StaticResource AccentPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="B" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Compact secondary button (subtle fill + border) -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="B" CornerRadius="8" Padding="{TemplateBinding Padding}"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="B" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="B" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Buy-me-a-coffee CTA in the sidebar (warm amber, stands apart from the indigo accent) -->
    <SolidColorBrush x:Key="CoffeeBrush" Color="#F5A623" />
    <SolidColorBrush x:Key="CoffeeHoverBrush" Color="#FFBA3D" />
    <Style x:Key="SidebarCoffeeButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="#1B1206" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Margin" Value="0,2,0,6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="B" Background="{StaticResource CoffeeBrush}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="B" Property="Background" Value="{StaticResource CoffeeHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar action row: a Button that mimics NavItemStyle (for external links like Report an issue) -->
    <Style x:Key="SidebarActionStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent" CornerRadius="8">
                        <ContentPresenter Margin="16,0,12,0" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource SidebarItemHoverBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource SidebarTextActiveBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Small, muted "check for updates" row for the very bottom corner of the sidebar -->
    <Style x:Key="SidebarUpdateStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource SidebarMutedBrush}" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent" CornerRadius="6">
                        <ContentPresenter Margin="16,0,8,0" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource SidebarItemHoverBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Section header label: small, muted -->
    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>

    <!-- Field explanation ("hint") box: rounded corners, accent-coloured border, light accent tint. -->
    <SolidColorBrush x:Key="AccentTintBrush" Color="#1F6366F1" />
    <Style x:Key="HintBoxStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{StaticResource AccentTintBrush}" />
        <Setter Property="Padding" Value="9,6" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Style.Triggers>
            <!-- Hidden when the "?" button turns help off (no ShowHelp in scope elsewhere = stays shown). -->
            <DataTrigger Binding="{Binding ShowHelp}" Value="False">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="HintTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="15.5" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>

</ResourceDictionary>
